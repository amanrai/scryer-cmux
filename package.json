{
  "name": "scryer-cmux",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "concurrently -k -n terminal,vite -c yellow,blue \"node server/terminal-server.mjs\" \"vite --host 0.0.0.0\"",
    "dev:ui": "vite --host 0.0.0.0",
    "dev:terminal": "node server/terminal-server.mjs",
    "dev:gateway": "node server-gateway/gateway-server.mjs",
    "dev:pty:api": "node server-pty/pty-server.mjs",
    "dev:pty:ui": "node server-pty/admin-ui.mjs",
    "dev:pty": "concurrently -k -n pty-api,pty-ui -c yellow,cyan \"node server-pty/pty-server.mjs\" \"node server-pty/admin-ui.mjs\"",
    "pty": "npm run dev:pty",
    "dev:bifurcated": "concurrently -k -n pty,gateway,vite -c yellow,magenta,blue \"npm run dev:pty\" \"node server-gateway/gateway-server.mjs\" \"VITE_SCRYER_CMUX_API_PORT=43223 vite --host 0.0.0.0\"",
    "postinstall": "node server/fix-node-pty.mjs",
    "build": "tsc -b && vite build",
    "preview": "vite preview --host 0.0.0.0",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@types/react": "latest",
    "@types/react-dom": "latest",
    "@vitejs/plugin-react": "latest",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/addon-image": "^0.9.0",
    "@xterm/xterm": "^6.0.0",
    "concurrently": "^10.0.3",
    "node-pty": "^1.1.0",
    "react": "latest",
    "react-dom": "latest",
    "typescript": "latest",
    "vite": "latest",
    "ws": "^8.21.0"
  }
}
