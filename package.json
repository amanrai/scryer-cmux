{
  "name": "scryer-cmux",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "concurrently -k -n terminal,vite -c yellow,blue \"node server/terminal-server.mjs\" \"vite --host 0.0.0.0\"",
    "dev:ui": "vite --host 0.0.0.0",
    "dev:terminal": "node server/terminal-server.mjs",
    "postinstall": "node server/fix-node-pty.mjs",
    "build": "tsc -b && vite build",
    "preview": "vite preview --host 0.0.0.0",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@types/react": "latest",
    "@types/react-dom": "latest",
    "@vitejs/plugin-react": "latest",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/addon-image": "^0.9.0",
    "@xterm/xterm": "^6.0.0",
    "concurrently": "^10.0.3",
    "node-pty": "^1.1.0",
    "react": "latest",
    "react-dom": "latest",
    "typescript": "latest",
    "vite": "latest",
    "ws": "^8.21.0"
  }
}
