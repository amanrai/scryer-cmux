<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <!-- The gateway/PTY are reached over cleartext http:// and ws:// on a local /
         Tailscale network, so allow arbitrary loads. Tighten to NSExceptionDomains
         if the gateway ever gets a fixed HTTPS host. -->
    <key>NSAppTransportSecurity</key>
    <dict>
        <key>NSAllowsArbitraryLoads</key>
        <true/>
    </dict>
    <!-- Voice dictation: mic capture + on-device speech recognition. -->
    <key>NSMicrophoneUsageDescription</key>
    <string>Dictate commands and prompts to the terminal by voice.</string>
    <key>NSSpeechRecognitionUsageDescription</key>
    <string>Transcribe your speech on-device to type into the terminal.</string>
</dict>
</plist>
